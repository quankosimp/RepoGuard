{
  "version": 2,
  "name": "repoguard-system-benchmark",
  "description": "Expanded benchmark for scanner, codegraph, patcher and verifier coverage.",
  "cases": [
    {
      "repo_id": "base64_exec",
      "path": "corpus/malicious/base64_exec.py",
      "label": "malicious",
      "category": "malware",
      "stage": "scan",
      "expected_rules": ["PY-DECODE-EXEC"],
      "expected_findings": [
        {
          "rule_id": "PY-DECODE-EXEC",
          "target_region": {
            "file": "base64_exec.py",
            "start_line": 6,
            "end_line": 6
          },
          "min_severity": "high",
          "behavior_path_contains": [
            "SOURCE: encoded string",
            "TRANSFORM: base64/hex decode",
            "SINK: exec"
          ]
        }
      ],
      "expected_patch": {
        "required": true,
        "mode": "apply",
        "target_rule": "PY-DECODE-EXEC",
        "expected_action": "quarantine",
        "max_rounds": 3,
        "min_severity": "high",
        "expected_verification": {
          "status": "patched",
          "scanner_passed": true
        }
      }
    },
    {
      "repo_id": "env_exfil",
      "path": "corpus/malicious/env_exfil.py",
