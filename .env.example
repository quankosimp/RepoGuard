# Required for `python3 -m repoguard fix ...`
OPENAI_API_KEY=sk-your-api-key-here

# Optional. Override if your account uses another remediation-capable model.
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=120

# Optional. Set to 1 to disable CodeGraph enrichment even when codegraph is installed.
REPOGUARD_DISABLE_CODEGRAPH=0
